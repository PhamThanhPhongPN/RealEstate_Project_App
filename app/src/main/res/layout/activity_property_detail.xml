<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Image Slider Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager_images"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Dot Indicator -->
                <TextView
                    android:id="@+id/tv_image_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_margin="16dp"
                    android:background="#80000000"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="1/1"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <!-- Toolbar Overlaid -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:padding="12dp">

                    <ImageButton
                        android:id="@+id/btn_back"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_translucent"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/white" />

                    <ImageButton
                        android:id="@+id/btn_report"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_toStartOf="@id/btn_favorite"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_circle_translucent"
                        android:src="@android:drawable/ic_menu_report_image"
                        app:tint="@color/white" />

                    <ImageButton
                        android:id="@+id/btn_favorite"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_circle_translucent"
                        android:src="@drawable/ic_favorite"
                        app:tint="@color/white" />
                </RelativeLayout>
            </RelativeLayout>

            <!-- Main Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title & Price Row -->
                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Price with USD/VND Converter Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/brand_blue_600"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_currency_toggle"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem giá VND"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <!-- Location Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/brand_blue_600" />

                    <TextView
                        android:id="@+id/tv_detail_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="@color/gray_700"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- ── Map Section (new, shown only when lat/lng available) ── -->
                <LinearLayout
                    android:id="@+id/layout_map_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vị trí trên bản đồ"
                        android:textColor="@color/brand_blue_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <WebView
                        android:id="@+id/web_view_map"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
                <!-- ── End Map Section ── -->

                <!-- Specs grid box -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@color/brand_blue_50"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="4">

                    <!-- Beds -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phòng ngủ"
                            android:textColor="@color/gray_500"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_detail_beds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/brand_blue_900"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Baths -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phòng tắm"
                            android:textColor="@color/gray_500"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_detail_baths"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/brand_blue_900"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Area -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diện tích"
                            android:textColor="@color/gray_500"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_detail_area"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/brand_blue_900"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Direction -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hướng"
                            android:textColor="@color/gray_500"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_detail_direction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/brand_blue_900"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Mô tả chi tiết"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/gray_700"
                    android:textSize="14sp" />

                <!-- Amenities/Features Grid -->
                <TextView
                    android:id="@+id/tv_detail_features_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Tiện ích đi kèm"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_detail_features"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

                <!-- Mortgage Calculator Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Công Cụ Tính Trả Góp"
                            android:textColor="@color/brand_blue_600"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Monthly payment display -->
                        <TextView
                            android:id="@+id/tv_mortgage_monthly_payment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:textColor="@color/brand_blue_900"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <!-- Principal Amount -->
                        <TextView
                            android:id="@+id/tv_mortgage_principal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <!-- Down Payment Slider -->
                        <TextView
                            android:id="@+id/tv_label_down_payment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Trả trước (Down Payment): 20%"
                            android:textSize="13sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_down_payment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0.0"
                            android:valueTo="100.0"
                            android:value="20.0"
                            app:thumbColor="@color/brand_blue_600"
                            app:trackColorActive="@color/brand_blue_600" />

                        <!-- Interest Rate Slider -->
                        <TextView
                            android:id="@+id/tv_label_interest_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Lãi suất hàng năm: 6.5%"
                            android:textSize="13sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_interest_rate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0.0"
                            android:valueTo="20.0"
                            android:value="6.5"
                            app:thumbColor="@color/brand_blue_600"
                            app:trackColorActive="@color/brand_blue_600" />

                        <!-- Loan Term Slider -->
                        <TextView
                            android:id="@+id/tv_label_loan_term"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Kỳ hạn vay: 25 năm"
                            android:textSize="13sp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_loan_term"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="5.0"
                            android:valueTo="40.0"
                            android:value="25.0"
                            app:thumbColor="@color/brand_blue_600"
                            app:trackColorActive="@color/brand_blue_600" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Seller Info Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Người đăng tin"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iv_seller_avatar"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_seller_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/brand_blue_900"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_seller_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/gray_500"
                                android:textSize="13sp" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Similar Listings Section -->
                <TextView
                    android:id="@+id/tv_similar_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Bất Động Sản Tương Tự"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_similar_properties"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Contact Panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá bán/thuê"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_bottom_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_blue_600"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_contact_agent"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:backgroundTint="@color/brand_blue_600"
                android:text="Liên hệ chủ nhà"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_inbox"
                app:iconTint="@color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
