<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_blue_900"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LuxeEstates"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Khám phá không gian sống sang trọng"
                    android:textColor="#CBD5E1"
                    android:textSize="14sp" />

                <!-- Transaction Toggle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="#2E3A59"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <Button
                        android:id="@+id/btn_buy_toggle"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:backgroundTint="@color/white"
                        android:text="Mua Bán"
                        android:textColor="@color/brand_blue_600"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="80dp" />

                    <Button
                        android:id="@+id/btn_rent_toggle"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Cho Thuê"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="80dp" />
                </LinearLayout>

                <!-- Search Input Group -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <EditText
                        android:id="@+id/et_search_query"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_search_input"
                        android:hint="Nhập khu vực, tên dự án..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:paddingEnd="64dp"
                        android:paddingStart="16dp"
                        android:textColor="@color/white"
                        android:textColorHint="#94A3B8" />

                    <ImageButton
                        android:id="@+id/btn_quick_search"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="3dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_search"
                        app:tint="@color/white" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Categories -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:text="Loại Bất Động Sản"
                android:textColor="@color/brand_blue_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/cat_apartment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_inactive"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Căn hộ"
                        android:textColor="@color/brand_blue_600"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/cat_villa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_inactive"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Biệt thự"
                        android:textColor="@color/brand_blue_600"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/cat_penthouse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_inactive"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Penthouse"
                        android:textColor="@color/brand_blue_600"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/cat_house"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_inactive"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Nhà phố"
                        android:textColor="@color/brand_blue_600"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/cat_land"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_inactive"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Đất nền"
                        android:textColor="@color/brand_blue_600"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Featured Properties Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tin Nổi Bật"
                    android:textColor="@color/brand_blue_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_view_all_featured"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Xem tất cả"
                    android:textColor="@color/brand_blue_600"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Horizontal Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_featured"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
