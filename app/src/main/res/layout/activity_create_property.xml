<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_create_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/brand_blue_900" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng Tin Bất Động Sản"
            android:textColor="@color/brand_blue_900"
            android:textSize="16sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin chung"
                android:textColor="@color/brand_blue_600"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_create_title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext_bordered"
                android:hint="Tiêu đề tin đăng (bắt buộc)"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_create_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext_bordered"
                android:gravity="top|start"
                android:hint="Mô tả chi tiết tin đăng"
                android:inputType="textMultiLine"
                android:minLines="4"
                android:padding="12dp"
                android:textSize="14sp" />

            <!-- Transaction Choice & Type choice -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Hình thức &amp; Loại bất động sản"
                android:textColor="@color/brand_blue_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_create_listing_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_create_sale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Bán" />

                <RadioButton
                    android:id="@+id/rb_create_rent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="Cho thuê" />
            </RadioGroup>

            <Spinner
                android:id="@+id/spinner_create_type"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_spinner_bordered" />

            <!-- Price & Currency toggling -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Giá &amp; Diện tích"
                android:textColor="@color/brand_blue_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_create_price"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edittext_bordered"
                    android:hint="Giá"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinner_create_currency"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_spinner_bordered" />
            </LinearLayout>

            <!-- Price saved hint -->
            <TextView
                android:id="@+id/tv_create_price_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/brand_blue_600"
                android:textSize="11sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_create_area"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext_bordered"
                android:hint="Diện tích (m²)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <!-- Beds & Baths -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_create_bedrooms"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edittext_bordered"
                    android:hint="Số phòng ngủ"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_create_bathrooms"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edittext_bordered"
                    android:hint="Số phòng tắm"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Direction & Video URL -->
            <Spinner
                android:id="@+id/spinner_create_direction"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_spinner_bordered" />

            <EditText
                android:id="@+id/et_create_video_url"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext_bordered"
                android:hint="URL Video Tour (Youtube, v.v.)"
                android:inputType="textUri"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <!-- Location Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Vị trí bất động sản"
                android:textColor="@color/brand_blue_600"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinner_create_city"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner_bordered" />

                <Spinner
                    android:id="@+id/spinner_create_district"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner_bordered" />
            </LinearLayout>

            <EditText
                android:id="@+id/et_create_address"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext_bordered"
                android:hint="Địa chỉ chi tiết (Số nhà, tên đường...)"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <!-- ── Map Pin Block (new) ── -->
            <Button
                android:id="@+id/btn_create_pick_location"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:drawableStart="@android:drawable/ic_dialog_map"
                android:drawablePadding="8dp"
                android:text="Ghim vị trí trên bản đồ"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <TextView
                android:id="@+id/tv_create_location_coords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext_bordered"
                android:padding="10dp"
                android:text="Chưa chọn vị trí trên bản đồ"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                android:visibility="visible" />
            <!-- ── End Map Pin Block ── -->



            <!-- Media Section (Photo upload selector) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Hình ảnh bất động sản"
                android:textColor="@color/brand_blue_600"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn tối đa 10 ảnh tải lên (JPG, PNG, WEBP)"
                android:textColor="@color/gray_500"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_select_images"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn ảnh"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/tv_images_selected_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Đã chọn: 0 ảnh"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Horizontal previews list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_image_previews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />

            <!-- Amenities/Features Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Tiện ích đi kèm"
                android:textColor="@color/brand_blue_600"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_create_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_create_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#EF4444"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_create_submit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:backgroundTint="@color/brand_blue_600"
                android:text="Đăng tin ngay"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
